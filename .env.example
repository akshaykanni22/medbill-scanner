# ============================================================
# MedBill Scanner - Environment Variables
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file: cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env to git (it's in .gitignore)
# ============================================================

# --- Anthropic (required) ---
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- App settings ---
# How many results the RAG retriever returns per query
RAG_TOP_K=5

# Max file size for bill uploads (in MB)
MAX_UPLOAD_SIZE_MB=10

# Allowed file types (comma separated, no spaces)
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png

# --- Rate limiting ---
# Max requests per minute per IP (protects your API bill)
RATE_LIMIT_PER_MINUTE=10

# --- CORS ---
# Frontend URL - lock this down, never use * in production
FRONTEND_URL=http://localhost:3000

# --- CMS Data ---
# These URLs are public CMS.gov endpoints - no key needed
CMS_HCPCS_URL=https://www.cms.gov/files/zip/2025-alpha-numeric-hcpcs-file.zip
CMS_RVU_URL=https://www.cms.gov/files/zip/rvu25a.zip

# Absolute path to this project on your machine.
# Run: echo "MEDBILL_PROJECT_ROOT=$(pwd)" >> .env  from the project folder
MEDBILL_PROJECT_ROOT=medbill-scanner

# Where downloaded CMS data lives — relative to project root above
MEDBILL_DATA_DIR=medbill-scanner/data
